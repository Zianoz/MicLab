<UserControl x:Class="MicFX.Views.EqPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MicFX.Views"
             xmlns:conv="clr-namespace:MicFX.Converters">
    <UserControl.Resources>
        <conv:DbDisplayConverter x:Key="DbDisplay"/>
    </UserControl.Resources>

    <DockPanel>
        <!-- EQ frequency response curve -->
        <Border DockPanel.Dock="Top" Height="120" Background="#FF111111" Margin="8,8,8,4">
            <Canvas x:Name="EqCurveCanvas" ClipToBounds="True">
                <!-- Drawn in code-behind via EqCurveRenderer -->
                <Polyline x:Name="EqCurveLine"
                          Stroke="{StaticResource AccentBrush}"
                          StrokeThickness="2"
                          Points="0,60 900,60"/>
                <!-- Center line (0 dB) -->
                <Line X1="0" Y1="60" X2="900" Y2="60"
                      Stroke="#FF333333" StrokeThickness="1" StrokeDashArray="4 4"/>
            </Canvas>
        </Border>

        <!-- EQ sliders -->
        <ScrollViewer DockPanel.Dock="Bottom" HorizontalScrollBarVisibility="Auto"
                      VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Bands}" Margin="8,0,8,8">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Width="52" Margin="2,0" HorizontalAlignment="Center">
                            <!-- dB value label -->
                            <TextBlock Text="{Binding GainDb, Converter={StaticResource DbDisplay}}"
                                       Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,2"/>

                            <!-- Vertical slider -->
                            <Slider Orientation="Vertical"
                                    Height="120"
                                    Minimum="-12" Maximum="12"
                                    Value="{Binding GainDb, Mode=TwoWay}"
                                    TickFrequency="3"
                                    TickPlacement="BottomRight"
                                    Style="{StaticResource DarkSlider}"
                                    HorizontalAlignment="Center"/>

                            <!-- Frequency label -->
                            <TextBlock Text="{Binding FrequencyLabel}"
                                       Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
