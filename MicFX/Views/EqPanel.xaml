<UserControl x:Class="MicFX.Views.EqPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="clr-namespace:MicFX.Views"
             xmlns:conv="clr-namespace:MicFX.Converters">
    <UserControl.Resources>
        <conv:DbDisplayConverter x:Key="DbDisplay"/>
    </UserControl.Resources>

    <Grid Margin="8,8,8,10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid MaxWidth="860" HorizontalAlignment="Stretch">
            <Border Height="120"
                    Background="#FF0A101A"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                <Canvas x:Name="EqCurveCanvas" ClipToBounds="True" Margin="10,8">
                    <Line X1="0" Y1="52" X2="{Binding ActualWidth, ElementName=EqCurveCanvas}" Y2="52"
                          Stroke="#FF324865" StrokeThickness="1" StrokeDashArray="4 4"/>
                    <Path x:Name="EqCurveFill" Fill="#184CC9F0"/>
                    <Path x:Name="EqCurvePath"
                          Stroke="{StaticResource AccentBrush}"
                          StrokeThickness="1.8"
                          StrokeLineJoin="Round"/>
                </Canvas>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                MaxWidth="860"
                HorizontalAlignment="Stretch"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="12"
                Padding="10,12,10,8">
            <ItemsControl ItemsSource="{Binding Bands}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="1" Columns="10"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="2,0" HorizontalAlignment="Center"
                                    ToolTip="{Binding Description}"
                                    ToolTipService.ShowDuration="12000">
                            <TextBlock Text="{Binding GainDb, Converter={StaticResource DbDisplay}}"
                                       Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,2"/>
                            <Slider Orientation="Vertical"
                                    Height="112"
                                    Width="32"
                                    Minimum="-12" Maximum="12"
                                    Value="{Binding GainDb, Mode=TwoWay}"
                                    TickFrequency="3"
                                    TickPlacement="BottomRight"
                                    Style="{StaticResource DarkSlider}"
                                    HorizontalAlignment="Center"/>
                            <TextBlock Text="{Binding FrequencyLabel}"
                                       Style="{StaticResource FieldLabel}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</UserControl>
