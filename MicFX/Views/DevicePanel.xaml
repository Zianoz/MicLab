<UserControl x:Class="MicFX.Views.DevicePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MicFX.Converters">
    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InvBool"/>
        <conv:MuteLabelConverter x:Key="MuteLabel"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <StackPanel Margin="8">

        <!-- INPUT -->
        <TextBlock Text="INPUT" Style="{StaticResource SectionHeader}"/>
        <TextBlock Text="Microphone" Style="{StaticResource FieldLabel}"/>
        <ComboBox ItemsSource="{Binding InputDevices}"
                  SelectedItem="{Binding SelectedInput}"
                  DisplayMemberPath="FriendlyName"
                  Style="{StaticResource DarkComboBox}"
                  Margin="0,0,0,10"/>

        <!-- OUTPUT -->
        <TextBlock Text="OUTPUT" Style="{StaticResource SectionHeader}"/>
        <TextBlock Text="Virtual Cable" Style="{StaticResource FieldLabel}"/>
        <ComboBox ItemsSource="{Binding OutputDevices}"
                  SelectedItem="{Binding SelectedOutput}"
                  DisplayMemberPath="FriendlyName"
                  Style="{StaticResource DarkComboBox}"
                  Margin="0,0,0,4"/>

        <TextBlock Text="No virtual cable found. Install VB-CABLE to route audio to apps."
                   TextWrapping="Wrap"
                   Foreground="#FFFF8800"
                   FontSize="10"
                   Visibility="{Binding NoVirtualCableWarning, Converter={StaticResource BoolVis}}"
                   Margin="0,0,0,6"/>

        <!-- MONITOR -->
        <TextBlock Text="MONITOR" Style="{StaticResource SectionHeader}" Margin="0,6,0,0"/>
        <TextBlock Text="Headphones" Style="{StaticResource FieldLabel}"/>
        <ComboBox ItemsSource="{Binding MonitorDevices}"
                  SelectedItem="{Binding SelectedMonitor}"
                  DisplayMemberPath="FriendlyName"
                  Style="{StaticResource DarkComboBox}"
                  Margin="0,0,0,6"/>

        <TextBlock Text="Monitor Volume" Style="{StaticResource FieldLabel}"/>
        <Slider Minimum="0" Maximum="1"
                Value="{Binding MonitorVolume}"
                Style="{StaticResource DarkSlider}"
                IsEnabled="{Binding MonitorMuted, Converter={StaticResource InvBool}}"
                Margin="0,0,0,6"/>

        <Button Content="{Binding MonitorMuted, Converter={StaticResource MuteLabel}}"
                Command="{Binding ToggleMuteCommand}"
                Style="{StaticResource DarkButton}"
                HorizontalAlignment="Left"
                Width="70"/>

    </StackPanel>
</UserControl>
