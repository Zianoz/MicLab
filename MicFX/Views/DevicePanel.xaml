<UserControl x:Class="MicFX.Views.DevicePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MicFX.Converters">
    <UserControl.Resources>
        <conv:InverseBoolConverter x:Key="InvBool"/>
        <conv:MuteLabelConverter x:Key="MuteLabel"/>
        <BooleanToVisibilityConverter x:Key="BoolVis"/>
    </UserControl.Resources>

    <Border Style="{StaticResource CardBorder}">
        <StackPanel>
            <TextBlock Text="Audio Routing"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Choose your source, route target, and monitoring output."
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,4,0,18"/>

            <Border Style="{StaticResource CardBorder}" Background="{StaticResource SurfaceHighBrush}" Padding="14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="INPUT" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="Microphone Source" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding InputDevices}"
                              SelectedItem="{Binding SelectedInput}"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource DarkComboBox}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Background="{StaticResource SurfaceHighBrush}" Padding="14" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="OUTPUT" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="Route To App / Virtual Cable" Style="{StaticResource FieldLabel}"/>
                    <TextBlock Text="For VB-CABLE: choose CABLE Input here. In the other app, choose CABLE Output as the microphone/input."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap"
                               FontSize="11"
                               Margin="0,0,0,8"/>
                    <ComboBox ItemsSource="{Binding OutputDevices}"
                              SelectedItem="{Binding SelectedOutput}"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource DarkComboBox}"
                              Margin="0,0,0,8"/>

                    <Border Background="{StaticResource AccentSoftBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="10"
                            Visibility="{Binding NoVirtualCableWarning, Converter={StaticResource BoolVis}}">
                        <TextBlock Text="No route target found. VB-CABLE appears here as the render device named CABLE Input. The receiving app should use CABLE Output."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource WarningBrush}"
                                   FontSize="11"/>
                    </Border>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorder}" Background="{StaticResource SurfaceHighBrush}" Padding="14">
                <StackPanel>
                    <TextBlock Text="MONITOR" Style="{StaticResource SectionHeader}"/>
                    <TextBlock Text="Headphones" Style="{StaticResource FieldLabel}"/>
                    <ComboBox ItemsSource="{Binding MonitorDevices}"
                              SelectedItem="{Binding SelectedMonitor}"
                              DisplayMemberPath="DisplayName"
                              Style="{StaticResource DarkComboBox}"
                              Margin="0,0,0,12"/>

                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Monitor Volume" Style="{StaticResource FieldLabel}" DockPanel.Dock="Left"/>
                        <TextBlock Text="{Binding MonitorVolume, StringFormat={}{0:P0}}"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="SemiBold"
                                   DockPanel.Dock="Right"/>
                    </DockPanel>
                    <Slider Minimum="0" Maximum="2"
                            Value="{Binding MonitorVolume}"
                            Style="{StaticResource DarkSlider}"
                            IsEnabled="{Binding MonitorMuted, Converter={StaticResource InvBool}}"
                            Margin="0,0,0,12"/>

                    <Button Content="{Binding MonitorMuted, Converter={StaticResource MuteLabel}}"
                            Command="{Binding ToggleMuteCommand}"
                            Style="{StaticResource DarkButton}"
                            HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
