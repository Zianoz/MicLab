<UserControl x:Class="MicFX.Views.MeterPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MicFX.Converters">
    <UserControl.Resources>
        <conv:LevelToHeightConverter x:Key="LevelH"/>
    </UserControl.Resources>

    <Border Style="{StaticResource CardBorder}">
        <StackPanel>
            <TextBlock Text="Signal Levels"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"/>
            <TextBlock Text="Clean meter cards instead of the old blocky columns."
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,4,0,18"/>

            <TextBlock Text="INPUT" Style="{StaticResource SectionHeader}"/>
            <Border Background="{StaticResource SurfaceHighBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14"
                    Margin="0,0,0,12">
                <StackPanel>
                    <Grid Height="14">
                        <Border Height="14" Background="{StaticResource BackgroundBrush}" CornerRadius="7"/>
                        <Border Height="14"
                                HorizontalAlignment="Left"
                                Width="{Binding InputRmsDisplay, Converter={StaticResource LevelH}, ConverterParameter=250}"
                                Background="{StaticResource MeterGreenBrush}"
                                CornerRadius="7"/>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Silent" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="2" Text="Hot" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                    </Grid>
                </StackPanel>
            </Border>

            <TextBlock Text="OUTPUT" Style="{StaticResource SectionHeader}"/>
            <Border Background="{StaticResource SurfaceHighBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Padding="14">
                <StackPanel>
                    <Grid Height="14">
                        <Border Height="14" Background="{StaticResource BackgroundBrush}" CornerRadius="7"/>
                        <Border Height="14"
                                HorizontalAlignment="Left"
                                Width="{Binding OutputRmsDisplay, Converter={StaticResource LevelH}, ConverterParameter=250}"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="7"/>
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Low" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                        <TextBlock Grid.Column="2" Text="Full" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</UserControl>
