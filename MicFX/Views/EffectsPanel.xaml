<UserControl x:Class="MicFX.Views.EffectsPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:MicFX.Converters">
    <UserControl.Resources>
        <conv:DbDisplayConverter x:Key="DbDisplay"/>
    </UserControl.Resources>

    <UniformGrid Columns="2" Margin="8">

        <!-- NOISE GATE -->
        <Border Margin="0,0,4,0" Padding="8" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="NOISE GATE" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Threshold" Style="{StaticResource FieldLabel}"/>
                <TextBlock Text="{Binding GateThresholdDb, Converter={StaticResource DbDisplay}}"
                           Style="{StaticResource FieldLabel}" HorizontalAlignment="Right"/>
                <Slider Minimum="-80" Maximum="0" Value="{Binding GateThresholdDb}"
                        Style="{StaticResource DarkSlider}" Margin="0,0,0,6"/>

                <TextBlock Text="Attack (ms)" Style="{StaticResource FieldLabel}"/>
                <Slider Minimum="1" Maximum="200" Value="{Binding GateAttackMs}"
                        Style="{StaticResource DarkSlider}" Margin="0,0,0,6"/>

                <TextBlock Text="Hold (ms)" Style="{StaticResource FieldLabel}"/>
                <Slider Minimum="0" Maximum="1000" Value="{Binding GateHoldMs}"
                        Style="{StaticResource DarkSlider}" Margin="0,0,0,6"/>

                <TextBlock Text="Release (ms)" Style="{StaticResource FieldLabel}"/>
                <Slider Minimum="1" Maximum="500" Value="{Binding GateReleaseMs}"
                        Style="{StaticResource DarkSlider}"/>
            </StackPanel>
        </Border>

        <!-- COMPRESSOR -->
        <Border Margin="4,0,0,0" Padding="8" Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="COMPRESSOR" Style="{StaticResource SectionHeader}"/>

                <TextBlock Text="Threshold" Style="{StaticResource FieldLabel}"/>
                <TextBlock Text="{Binding CompThresholdDb, Converter={StaticResource DbDisplay}}"
                           Style="{StaticResource FieldLabel}" HorizontalAlignment="Right"/>
                <Slider Minimum="-60" Maximum="0" Value="{Binding CompThresholdDb}"
                        Style="{StaticResource DarkSlider}" Margin="0,0,0,6"/>

                <TextBlock Text="Ratio" Style="{StaticResource FieldLabel}"/>
                <Slider Minimum="1" Maximum="20" Value="{Binding CompRatio}"
                        Style="{StaticResource DarkSlider}" Margin="0,0,0,6"/>

                <TextBlock Text="Attack (ms)" Style="{StaticResource FieldLabel}"/>
                <Slider Minimum="1" Maximum="200" Value="{Binding CompAttackMs}"
                        Style="{StaticResource DarkSlider}" Margin="0,0,0,6"/>

                <TextBlock Text="Release (ms)" Style="{StaticResource FieldLabel}"/>
                <Slider Minimum="1" Maximum="500" Value="{Binding CompReleaseMs}"
                        Style="{StaticResource DarkSlider}" Margin="0,0,0,6"/>

                <TextBlock Text="Makeup Gain" Style="{StaticResource FieldLabel}"/>
                <TextBlock Text="{Binding CompMakeupGainDb, Converter={StaticResource DbDisplay}}"
                           Style="{StaticResource FieldLabel}" HorizontalAlignment="Right"/>
                <Slider Minimum="-12" Maximum="24" Value="{Binding CompMakeupGainDb}"
                        Style="{StaticResource DarkSlider}"/>
            </StackPanel>
        </Border>

    </UniformGrid>
</UserControl>
