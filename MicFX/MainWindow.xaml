<Window x:Class="MicFX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:MicFX.Views"
        xmlns:vm="clr-namespace:MicFX.ViewModels"
        mc:Ignorable="d"
        Title="MicFX"
        Width="1180" Height="760"
        MinWidth="840" MinHeight="560"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        StateChanged="Window_StateChanged"
        KeyDown="Window_KeyDown">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Padding="18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="MicFX"
                               FontSize="26"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Cleaner routing, faster preset handling, less dated UI."
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <Grid Grid.Column="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                        <TextBlock Text="Preset Name" Style="{StaticResource FieldLabel}"/>
                        <TextBox Text="{Binding ActivePresetName, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource DarkTextBox}"
                                 ToolTip="Type a preset name here before saving."/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="0,0,12,0">
                        <TextBlock Text="Saved Presets" Style="{StaticResource FieldLabel}"/>
                        <ComboBox ItemsSource="{Binding PresetNames}"
                                  SelectedItem="{Binding ActivePresetName}"
                                  Style="{StaticResource DarkComboBox}"
                                  ToolTip="Select an existing preset to load or overwrite."/>
                    </StackPanel>
                    <Button Grid.Column="2"
                            Width="84"
                            Margin="0,24,8,0"
                            Content="Save"
                            Command="{Binding SavePresetCommand}"
                            Style="{StaticResource DarkButton}"/>
                    <Button Grid.Column="3"
                            Width="84"
                            Margin="0,24,0,0"
                            Content="Load"
                            Command="{Binding LoadPresetCommand}"
                            Style="{StaticResource DarkButton}"/>
                </Grid>

                <Button Grid.Column="4"
                        Width="116"
                        Height="46"
                        Content="{Binding StartStopLabel}"
                        Command="{Binding StartStopCommand}"
                        Style="{StaticResource AccentButton}"
                        VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.05*" MinWidth="260"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="2.45*" MinWidth="420"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="16"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <views:MeterPanel Grid.Row="0" DataContext="{Binding MeterVM}"/>
                    <views:DevicePanel Grid.Row="2" DataContext="{Binding DeviceVM}"/>
                </Grid>

                <Border Grid.Column="2" Style="{StaticResource CardBorder}" Padding="10">
                    <DockPanel>
                        <views:EqPanel DockPanel.Dock="Top" DataContext="{Binding EqVM}"/>
                        <views:EffectsPanel DataContext="{Binding EqVM}"/>
                    </DockPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <Border Grid.Row="4" Style="{StaticResource CardBorder}" Padding="14,10">
            <DockPanel>
                <Ellipse DockPanel.Dock="Left"
                         Width="8"
                         Height="8"
                         Fill="{StaticResource AccentBrush}"
                         Margin="0,0,10,0"
                         VerticalAlignment="Center"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           Text="{Binding StatusMessage, TargetNullValue=Ready.}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>
    </Grid>
</Window>
