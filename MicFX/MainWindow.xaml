<Window x:Class="MicFX.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:views="clr-namespace:MicFX.Views"
        xmlns:vm="clr-namespace:MicFX.ViewModels"
        mc:Ignorable="d"
        Title="MicFX"
        Width="900" Height="600"
        MinWidth="800" MinHeight="500"
        Background="{StaticResource BackgroundBrush}"
        WindowStyle="SingleBorderWindow"
        StateChanged="Window_StateChanged"
        KeyDown="Window_KeyDown">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <DockPanel>
        <!-- Top toolbar / title area -->
        <Border DockPanel.Dock="Top" Background="{StaticResource SurfaceBrush}" Padding="12,6">
            <TextBlock Text="MicFX" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"/>
        </Border>

        <!-- Bottom status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource SurfaceBrush}" Padding="12,6">
            <DockPanel>
                <ComboBox DockPanel.Dock="Left" Width="160" Margin="0,0,8,0"
                          ItemsSource="{Binding PresetNames}"
                          SelectedItem="{Binding ActivePresetName}"
                          Style="{StaticResource DarkComboBox}"/>
                <Button DockPanel.Dock="Left" Content="Save" Width="60" Margin="0,0,4,0"
                        Command="{Binding SavePresetCommand}"
                        Style="{StaticResource DarkButton}"/>
                <Button DockPanel.Dock="Left" Content="Load" Width="60"
                        Command="{Binding LoadPresetCommand}"
                        Style="{StaticResource DarkButton}"/>
                <Button DockPanel.Dock="Right" Width="80"
                        Content="{Binding StartStopLabel}"
                        Command="{Binding StartStopCommand}"
                        Style="{StaticResource AccentButton}"/>
                <TextBlock VerticalAlignment="Center" Margin="12,0,0,0"
                           Foreground="#FFFF8800"
                           Text="{Binding StatusMessage}"
                           TextTrimming="CharacterEllipsis"/>
            </DockPanel>
        </Border>

        <!-- Main content area -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: device + meters -->
            <DockPanel Grid.Column="0" Background="{StaticResource SurfaceBrush}">
                <views:DevicePanel DockPanel.Dock="Top" DataContext="{Binding DeviceVM}"/>
                <views:MeterPanel DataContext="{Binding MeterVM}"/>
            </DockPanel>

            <!-- Right panel: EQ + Effects -->
            <DockPanel Grid.Column="1">
                <views:EqPanel DockPanel.Dock="Top" DataContext="{Binding EqVM}"/>
                <views:EffectsPanel DataContext="{Binding EqVM}"/>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
